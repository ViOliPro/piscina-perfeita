# ------------------------------------------------------------------
# Ambiente da API. Deixe vazio (ou "Production") para deploy real.
# Localmente, se quiser testar sem as travas de produção (CORS aberto pra
# qualquer origem, rate limit do login bem mais alto, HTTPS não exigido no
# JWT), defina:
#   ASPNETCORE_ENVIRONMENT=Development
# Nunca use Development em produção — isso reabre o CORS geral e afrouxa
# o rate limit de login.
# ------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=

# ------------------------------------------------------------------
# HTTPS / domínio — usado pelo serviço "caddy" do docker-compose.yml.
# Deixe "localhost" enquanto não houver um domínio de produção definido
# (o Caddy gera um certificado local automaticamente). Quando tiver um
# domínio real apontando pro servidor, só trocar aqui — o Caddy emite e
# renova o certificado Let's Encrypt sozinho.
# ------------------------------------------------------------------
DOMAIN=localhost

# Vazio = libera qualquer origem, e só funciona com ASPNETCORE_ENVIRONMENT=
# Development (ver acima). Em Production a API recusa subir se isso estiver
# vazio. Defina com o domínio do front em produção, ex.: https://app.piscinaperfeita.com.br
CORS_ALLOWED_ORIGINS=

# ------------------------------------------------------------------
# JWT — usado pela API para assinar/validar os tokens de autenticação
# ------------------------------------------------------------------
JWT_AUDIENCE=PiscinaPerfeita
JWT_ISSUER=PiscinaPerfeita
JWT_KEY=troque-por-uma-chave-aleatoria-de-pelo-menos-32-caracteres

# ------------------------------------------------------------------
# Postgres — usado pelo serviço "db" do docker-compose.yml.
# (POSTGRES_HOST não existe aqui de propósito: dentro do compose o host
# é sempre o nome do serviço, "db" — só importa fora do Docker.)
# ------------------------------------------------------------------
POSTGRES_PORT=5432
POSTGRES_DB=piscina_perfeita
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ------------------------------------------------------------------
# Usuário SuperAdmin criado automaticamente pelo seeder (DbInitializer)
# na primeira vez que a API sobe com o banco vazio.
# ------------------------------------------------------------------
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@piscinaperfeita.com
ADMIN_PASSWORD=troque-por-uma-senha-forte
ADMIN_CPF=
